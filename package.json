{
  "name": "aegis-bm-platform",
  "version": "0.3.0",
  "description": "AEGIS Build Master Platform Kernel",
  "main": "dist/server/index.js",
  "scripts": {
    "build": "tsc && npm run build:ui",
    "build:ui": "npm install --prefix ui && npm run build --prefix ui",
    "start": "node dist/src/server/index.js",
    "dev:server": "tsx --watch src/server/index.ts",
    "dev:ui": "npm run dev --prefix ui",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:ui\"",
    "posture:scan": "node scripts/posture-scan.mjs",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "express": "^5.2.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.2.0",
    "@types/uuid": "^10.0.0",
    "concurrently": "^9.2.1",
    "tsx": "^4.21.0"
  }
}